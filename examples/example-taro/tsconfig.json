{
  "compilerOptions": {
    "outDir": "./dist/temp",
    "rootDir": "src",
    "baseUrl": ".",
    "jsx": "react-jsx",
    "allowJs": true,
    "experimentalDecorators": true,
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "*.js",
    "*.d.ts",
    "src",
    "config/**/*.js",
    "test",
    "eslint.config.mjs"
  ],
  "exclude": ["node_modules"]
}
